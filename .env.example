# AI Chatbot API Keys (at least one required)
# Groq is tried first (faster, more generous free limits), Gemini as fallback

# Get a free Groq key from https://console.groq.com (Recommended - 30 RPM free)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Get a free Gemini key from https://aistudio.google.com (10 RPM free)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# For production (GitHub Pages), add these as GitHub Repository Secrets:
# Go to your repo → Settings → Secrets and Variables → Actions → New Repository Secret
